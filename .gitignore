# ============================================================
# SecureGuard .gitignore — Node + Python + Expo
# ============================================================

# ── Secretos ─────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
ENV/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# ── Node / npm ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/
.pnp.*

# ── Next.js ───────────────────────────────────────────────────
admin/.next/
admin/out/
admin/.vercel/

# ── Expo / React Native ───────────────────────────────────────
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/.expo-shared/
*.orig.*
*.jks
*.p8
*.p12
*.mobileprovision
*.orig.*
google-services.json
GoogleService-Info.plist

# ── Editors ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
desktop.ini
