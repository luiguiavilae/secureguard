# ============================================================
# SecureGuard — Variables de Entorno
# Copiar a .env y completar con valores reales
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Backend FastAPI ───────────────────────────────────────────
BACKEND_SECRET_KEY=your-backend-secret-key-min-32-chars
BACKEND_PORT=8000
BACKEND_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ── Twilio (OTP / SMS) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Stripe (Pagos) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Admin Panel (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
ADMIN_NEXTAUTH_SECRET=your-nextauth-secret
ADMIN_NEXTAUTH_URL=http://localhost:3000

# ── Mobile (Expo) ─────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Maps (distritos / geolocalización) ─────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Expo Push Notifications ───────────────────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token
