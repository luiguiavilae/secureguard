{
  "expo": {
    "name": "SecureGuard",
    "slug": "secureguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.secureguard.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SecureGuard necesita tu ubicación para encontrar agentes cercanos.",
        "NSCameraUsageDescription": "SecureGuard necesita acceso a la cámara para subir documentos.",
        "NSPhotoLibraryUsageDescription": "SecureGuard necesita acceso a tus fotos para subir documentos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.secureguard.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1a1a2e"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SecureGuard necesita tu ubicación."
        }
      ]
    ],
    "scheme": "secureguard",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
