{
  "expo": {
    "name": "Salvus",
    "slug": "salvus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "updates": {
      "enabled": false
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.salvus.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Salvus necesita tu ubicación para encontrar agentes cercanos.",
        "NSCameraUsageDescription": "Salvus necesita acceso a la cámara para subir documentos.",
        "NSPhotoLibraryUsageDescription": "Salvus necesita acceso a tus fotos para subir documentos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.salvus.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1a1a2e"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Salvus necesita tu ubicación."
        }
      ]
    ],
    "scheme": "salvus",
    "extra": {
      "eas": {
        "projectId": "98a73090-1604-480c-b79b-9d92c7f36e5d"
      }
    }
  }
}
